{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning",
        "System.Net.Http": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "SyncConfig": {
    "LibraryPath": "/path/to/your/library",
    "ArtworkApiUrl": "http://localhost:5277",
    "DelayBetweenApiRequestsMs": 2000,
    "FfmpegBinaryPath": "ffmpeg",
    "MinVariantResolution": 1000,
    "WebpQuality": 50
  }
}